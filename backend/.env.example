# AI Interview System Environment Configuration
# Copy to .env and fill in your values

GEMINI_API_KEY=AIzaSy...your_actual_gemini_key_here...
# Get free key from https://aistudio.google.com/app/apikey

FLASK_SECRET_KEY=your-super-secret-key-here-change-in-production
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database
DATABASE_PATH=interviews.db

# CORS (add your frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Interview settings
MAX_WARNINGS=3
QUESTIONS_PER_INTERVIEW=10

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Backups
AUTO_BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

